# ==== PostgreSQL ====
POSTGRES_USER=focusflow
POSTGRES_PASSWORD=focusflow
POSTGRES_DB=focusflow
POSTGRES_PORT=5432

# ==== Backend ====
BACKEND_PORT=8000
# Внутри docker-compose host = postgres (имя сервиса)
DATABASE_URL=postgresql+asyncpg://focusflow:focusflow@postgres:5432/focusflow

# CORS (через запятую)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==== LLM (Groq) ====
# Получить бесплатный ключ: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ==== Frontend ====
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000/api/v1
